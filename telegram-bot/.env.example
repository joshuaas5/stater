# Configuração do arquivo .env para o bot do Telegram
# Copie este conteúdo para telegram-bot/.env

# ================================
# CONFIGURAÇÕES DO TELEGRAM BOT
# ================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
APP_URL=https://your-app-url.netlify.app

# ================================
# CONFIGURAÇÕES DO SUPABASE
# ================================
SUPABASE_URL=https://tmucbwlhkffrhtexmjze.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ================================
# CONFIGURAÇÕES DO GEMINI AI
# ================================
GEMINI_API_KEY=your_gemini_api_key_here

# ================================
# INSTRUÇÕES IMPORTANTES
# ================================
# 1. Substitua todos os valores "your_*_here" pelos valores reais
# 2. O SERVICE_ROLE_KEY é CRÍTICO para evitar erro 406
# 3. Mantenha essas chaves em segurança
# 4. Não commite este arquivo no Git
