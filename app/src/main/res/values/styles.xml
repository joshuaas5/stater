<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    
    <!-- 🖤 TEMA PRETO - STATUS BAR PRETA SÓLIDA -->
    <style name="BaseTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <!-- 🖤 STATUS BAR PRETA SÓLIDA - ANTI-FLASH BRANCO -->
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/black</item>
        
        <!-- 🌟 NAVIGATION BAR TRANSPARENTE -->
        <item name="android:navigationBarColor" tools:targetApi="l">@android:color/transparent</item>
        
        <!-- 🔵 FUNDO AZUL PARA EVITAR FLASH BRANCO -->
        <item name="android:windowBackground">@color/backgroundColor</item>
        
        <!-- 📱 CONFIGURAÇÕES EDGE-TO-EDGE -->
        <item name="android:windowDrawsSystemBarBackgrounds" tools:targetApi="l">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        
        <!-- 📱 SUPORTE PARA DISPOSITIVOS COM NOTCH/ILHA DINÂMICA -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="p">shortEdges</item>
        
        <!-- ⚪ ÍCONES BRANCOS (CONTRASTE COM PRETO) -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">false</item>
        
        <!-- 🔵 CORES AZUIS CONSISTENTES -->
        <item name="android:colorPrimary" tools:targetApi="l">@color/colorPrimary</item>
        <item name="android:colorPrimaryDark" tools:targetApi="l">@color/colorPrimaryDark</item>
        <item name="android:colorAccent" tools:targetApi="l">@android:color/white</item>
    </style>
    
    <!-- 🎯 TEMA PRINCIPAL DO TWA - STATUS BAR PRETA SÓLIDA -->
    <style name="Theme.TwaLauncher" parent="BaseTheme">
        <!-- 🖤 STATUS BAR PRETA SÓLIDA - NÃO TRANSPARENTE -->
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/black</item>
        <item name="android:windowBackground">@color/backgroundColor</item>
        
        <!-- ⚪ ÍCONES SEMPRE BRANCOS PARA FUNDO PRETO -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">false</item>
    </style>
    
    <!-- 📱 TEMA ALTERNATIVO PARA COMPATIBILIDADE LEGACY -->
    <style name="AppTheme" parent="Theme.TwaLauncher">
        <!-- Herda toda a configuração do Theme.TwaLauncher -->
    </style>
    
    <!-- 📱 TEMA SEM ACTION BAR PARA COMPATIBILIDADE -->
    <style name="AppTheme.NoActionBar" parent="Theme.TwaLauncher">
        <!-- Herda toda a configuração do Theme.TwaLauncher -->
    </style>
    
    <!-- 🚪 TEMA PARA LAUNCHER ACTIVITY -->
    <style name="LauncherTheme" parent="Theme.TwaLauncher">
        <item name="android:windowBackground">@color/backgroundColor</item>
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/black</item>
    </style>
    
    <!-- 🎬 TEMA SPLASH - STATUS BAR PRETA CONSISTENTE -->
    <style name="SplashTheme" parent="Theme.TwaLauncher">
        <item name="android:windowBackground">@color/backgroundColor</item>
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/black</item>
    </style>
    
</resources>
