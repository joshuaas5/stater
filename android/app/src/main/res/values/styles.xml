<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    
    <!-- TEMA BASE -->
    <style name="BaseTheme" parent="Theme.AppCompat.NoActionBar">
        <!-- STATUS BAR AZUL (não transparente) -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/status_bar_color</item>
        
        <!-- NAVIGATION BAR PRETA -->
        <item name="android:navigationBarColor" tools:targetApi="l">@color/navigationColor</item>
        
        <!-- FUNDO AZUL -->
        <item name="android:windowBackground">@color/backgroundColor</item>
        
        <!-- CONFIGURAÇÕES DE WINDOW -->
        <item name="android:windowDrawsSystemBarBackgrounds" tools:targetApi="l">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        
        <!-- SUPORTE PARA NOTCH -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="p">shortEdges</item>
        
        <!-- ÍCONES BRANCOS NA STATUS BAR (false = brancos) -->
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o">false</item>
        
        <!-- CORES -->
        <item name="android:colorPrimary" tools:targetApi="l">@color/colorPrimary</item>
        <item name="android:colorPrimaryDark" tools:targetApi="l">@color/colorPrimaryDark</item>
        <item name="android:colorAccent" tools:targetApi="l">@android:color/white</item>
    </style>
    
    <!-- TEMA PRINCIPAL -->
    <style name="Theme.TwaLauncher" parent="BaseTheme">
        <!-- Herda tudo do BaseTheme -->
    </style>
    
    <!-- TEMAS DE COMPATIBILIDADE -->
    <style name="AppTheme" parent="Theme.TwaLauncher" />
    <style name="AppTheme.NoActionBar" parent="Theme.TwaLauncher" />
    
    <!-- SPLASH SCREEN -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.TwaLauncher">
        <item name="android:windowBackground">@drawable/splash</item>
    </style>
    
</resources>
