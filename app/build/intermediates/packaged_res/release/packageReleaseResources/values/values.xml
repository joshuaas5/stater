<?xml version="1.0" encoding="utf-8"?>
<resources>
    <bool name="enableNotification">true</bool>
    <bool name="enableSiteSettingsShortcut">true</bool>
    <color name="backgroundColor">#1D4ED8</color>
    <color name="colorPrimary">#1D4ED8</color>
    <color name="colorPrimaryDark">#000000</color>
    <color name="navigationColor">#000000</color>
    <color name="navigationColorDark">#000000</color>
    <color name="navigationDividerColor">#000000</color>
    <color name="navigationDividerColorDark">#000000</color>
    <color name="shortcut_background">#F5F5F5</color>
    <color name="statusBarBlue">#31518b</color>
    <integer name="splashScreenFadeOutDuration">300</integer>
    <string name="appName" translatable="false">Stater</string>
    <string name="assetStatements">
    [{
        \"relation\": [\"delegate_permission/common.handle_all_urls\"],
        \"target\": {
            \"namespace\": \"web\",
            \"site\": \"https://stater.app\"
        }
    }]
    
  </string>
    <string name="fallbackType" translatable="false">customtabs</string>
    <string name="fullScopeUrl" translatable="false">https://stater.app/</string>
    <string name="generatorApp" translatable="false">bubblewrap-cli</string>
    <string name="hostName" translatable="false">stater.app</string>
    <string name="launchUrl" translatable="false">https://stater.app/login</string>
    <string name="launcherName" translatable="false">Stater</string>
    <string name="orientation" translatable="false">portrait-primary</string>
    <string name="providerAuthority" translatable="false">com.timothy.stater.fileprovider</string>
    <string name="webManifestUrl" translatable="false">https://stater.app/manifest.json</string>
    <style name="AppTheme" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <item name="android:navigationBarColor">@color/navigationColor</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>
    <style name="AppTheme.NoActionBar" parent="@android:style/Theme.DeviceDefault.NoActionBar">
        <item name="android:statusBarColor">@color/colorPrimary</item>
        <item name="android:navigationBarColor">@color/navigationColor</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
    </style>
</resources>